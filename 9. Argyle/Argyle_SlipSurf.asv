figure;
imagesc(alpha, b, area_diff);  % x: alpha, y: baseline depth
set(gca, 'YDir', 'normal');
colorbar;
xlabel('\alpha (deg)');
ylabel('b (baseline elevation)');
title('area\_diff(i,j) = A_{pre} - A_{post}');
